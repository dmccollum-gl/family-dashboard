# ── Cloudflare ──────────────────────────────────────────────────────────────
# API token with Cloudflare Tunnel:Edit and DNS:Edit permissions
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Found at dash.cloudflare.com → account home (URL contains the account ID)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Zone ID of mccollumtechnology.com (found on the zone overview page)
CLOUDFLARE_ZONE_ID=your_zone_id_here

BASE_DOMAIN=mccollumtechnology.com

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Google Cloud project that owns the OAuth 2.0 client
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id

# Client ID of the OAuth 2.0 web application credential
# (found at APIs & Services → Credentials in Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com

# Service account JSON — either an inline JSON string (paste the whole file
# content on one line) or an absolute path to the JSON key file.
# The SA must have the "OAuth Config Editor" role on the project.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# ── Server ───────────────────────────────────────────────────────────────────
# Random secret used to protect admin endpoints
ADMIN_API_KEY=change-me-to-a-random-secret

DATABASE_URL=sqlite:///./server.db

# Fernet encryption key for tunnel tokens at rest.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ── Multi-server sync ─────────────────────────────────────────────────────────
# Optional separate key for peer sync endpoints (X-Sync-Key header).
# Defaults to ADMIN_API_KEY if left blank.
SYNC_KEY=

# How often (seconds) the background loop pulls from all peers for reconciliation.
# Default: 300 (5 minutes)
SYNC_INTERVAL_SECONDS=300
