GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Leave SECRET_KEY blank — pi/setup.sh generates a unique random key on first
# boot and writes it here. It signs session cookies; a shared/default value
# would let anyone forge a login. Only set this manually for local dev.
SECRET_KEY=
FRONTEND_URL=http://localhost:5173

# Optional self-hosted tunnel provisioning server. Leave empty for a normal
# install — the dashboard sets up Cloudflare tunnels directly from Settings.
PROVISIONING_SERVER_URL=
